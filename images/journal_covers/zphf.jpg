<div class=" NavBarElementTypeTextElement NavBarElement0" id="NavElement_105602237">
  
  <div class="NavigationText " >
  <p><img alt="App" class="ep-gadget epgadget-contentslider" data-ep-gadget="{&quot;options&quot;:{&quot;effect&quot;:&quot;fade&quot;,&quot;arrows&quot;:false,&quot;shadow&quot;:false,&quot;border&quot;:&quot;transparent&quot;,&quot;automatic&quot;:true,&quot;displaytime&quot;:3,&quot;slides&quot;:[{&quot;name&quot;:&quot;priou.png&quot;,&quot;fullpath&quot;:&quot;/WebRoot/Store21/Shops/63574303/MediaGallery/,ContentSlider/priou.png&quot;,&quot;href&quot;:&quot;https://www.klostermann.de/epages/63574303.sf/de_DE/?ObjectPath=/Shops/63574303/Products/9783465047605&quot;,&quot;title&quot;:&quot;&quot;,&quot;target&quot;:&quot;&quot;,&quot;linkType&quot;:&quot;external&quot;},{&quot;name&quot;:&quot;dierks.png&quot;,&quot;fullpath&quot;:&quot;/WebRoot/Store21/Shops/63574303/MediaGallery/,ContentSlider/dierks.png&quot;,&quot;href&quot;:&quot;https://www.klostermann.de/epages/63574303.sf/de_DE/?ObjectPath=/Shops/63574303/Products/9783465047520&quot;,&quot;title&quot;:&quot;&quot;,&quot;target&quot;:&quot;&quot;,&quot;linkType&quot;:&quot;external&quot;},{&quot;name&quot;:&quot;pier.png&quot;,&quot;fullpath&quot;:&quot;/WebRoot/Store21/Shops/63574303/MediaGallery/,ContentSlider/pier.png&quot;,&quot;href&quot;:&quot;https://www.klostermann.de/epages/63574303.sf/de_DE/?ObjectPath=/Shops/63574303/Products/9783465047063&quot;,&quot;title&quot;:&quot;&quot;,&quot;target&quot;:&quot;&quot;,&quot;linkType&quot;:&quot;external&quot;},{&quot;name&quot;:&quot;mannheim.png&quot;,&quot;fullpath&quot;:&quot;/WebRoot/Store21/Shops/63574303/MediaGallery/,ContentSlider/mannheim.png&quot;,&quot;href&quot;:&quot;https://www.klostermann.de/epages/63574303.sf/de_DE/?ObjectPath=/Shops/63574303/Products/9783465047506&quot;,&quot;title&quot;:&quot;&quot;,&quot;target&quot;:&quot;&quot;,&quot;linkType&quot;:&quot;external&quot;},{&quot;name&quot;:&quot;pp_3_doering.png&quot;,&quot;fullpath&quot;:&quot;/WebRoot/Store21/Shops/63574303/MediaGallery/,ContentSlider/pp_3_doering.png&quot;,&quot;href&q